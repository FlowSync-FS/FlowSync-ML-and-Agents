.env
.env.*
!.env.example

# ── Personal / local Claude settings (not for the repo) ──────────────────────
CLAUDE.local.md

# ── Python bytecode ───────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

